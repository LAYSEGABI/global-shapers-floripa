{
  "rewrites": [
    {
      "source": "/ecotrilhas/:path*",
      "destination": "https://ecotrilhas.vercel.app/:path*"
    },
    {
      "source": "/ecotrilhas",
      "destination": "https://ecotrilhas.vercel.app"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}